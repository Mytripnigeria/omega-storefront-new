# Base URL of the omega-backend API (no trailing slash). Defaults to
# http://localhost:9091/api in development if unset.
VITE_API_URL=http://localhost:9091/api

# Business this storefront belongs to. The storefront is multi-tenant on the
# backend, but each deployed storefront serves exactly one business — this is
# the BusinessEntity.id whose menu, stores, theme, and orders should appear.
# Required: register/login and the menu fetch will return empty without it.
# Leave blank to resolve the business by the request hostname (custom domain)
# via GET /public/storefront/resolve — useful for multi-tenant deployments.
VITE_BUSINESS_ID=

# Google OAuth client ID for "Continue with Google" (must match the backend's
# GOOGLE_CLIENT_ID). Leave blank to hide the Google buttons.
VITE_GOOGLE_CLIENT_ID=

# Google Maps JS API key for the delivery-address map picker. Leave blank to
# fall back to plain text address entry.
VITE_GOOGLE_MAPS_API_KEY=
